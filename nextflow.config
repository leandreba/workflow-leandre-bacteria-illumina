apptainer {
    enabled = true
    cacheDir = "$projectDir/containers"
}

process {
    withName:fastqc {
        container = "docker://staphb/fastqc:0.12.1"}   
    
    withName:fastp {
        container = "docker://staphb/fastp:1.1.0"
    }

    withName:spades {
        container = "docker://staphb/spades:4.2.0"
    }
}
    